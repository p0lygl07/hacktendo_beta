import os, pty, json, threading, random, subprocess, base64, glob, zipfile, shutil, time
from flask import Flask, request, jsonify, send_from_directory
from flask_socketio import SocketIO, emit

# --- EXPANSION IMPORTS ---
try: import s_core
except ImportError: s_core = None
try: import ecore
except ImportError: ecore = None
try: import pcore
except ImportError: pcore = None
try: import tcore
except ImportError: tcore = None

app = Flask(__name__)
app.config['SEND_FILE_MAX_AGE_DEFAULT'] = 0 
socketio = SocketIO(app, cors_allowed_origins="*", async_mode='threading')

class SystemLedger:
    def sync(self, handle):
        path = f"profiles/{handle}.json"
        os.makedirs("profiles", exist_ok=True)
        if os.path.exists(path):
            with open(path, 'r') as f: return json.load(f)
        # Standardized to 'ledger' to match pcore
        data = {
            "handle": handle, "ledger": 750.0, "xp": 0, "level": 1, 
            "karma": 0, "inventory": [], "bio": "",
            "nodes": 0, "passive_rate": 0.0
        }
        with open(path, 'w') as f: json.dump(data, f)
        return data

ledger = SystemLedger()
fd = None
active_operators = {} 

# --- HELPER BINDING ---
def bind_route(url, name, func, methods=['GET']):
    app.add_url_rule(url, name, func, methods=methods)

# --- CORE HTML ROUTES ---
@app.route('/')
def index(): return send_from_directory('.', 'deck.html')

@app.route('/s-deck')
def sub_deck_route(): return send_from_directory('.', 's-deck.html')

@app.route('/e-deck')
def e_deck_route(): return send_from_directory('.', 'edeck.html')

@app.route('/profile')
def profile_page(): return send_from_directory('.', 'profile.html')

@app.route('/loader')
def loader_page(): return send_from_directory('.', 'loader.html')

# --- IDENTITY & TASKS ---
@app.route('/api/init_identity', methods=['POST'])
def init_identity():
    data = request.json
    handle = data.get('handle', 'OPERATOR').upper()
    profile = pcore.load_profile(handle) if pcore else ledger.sync(handle)
    if pcore: pcore.save_profile(profile, handle)
    active_operators[handle] = time.time()
    return jsonify({"status": "SUCCESS", "handle": handle, "profile": profile})

@app.route('/api/get_profile', methods=['GET', 'POST'])
def get_profile():
    data = request.get_json(silent=True) if request.method == 'POST' else request.args
    handle = data.get("handle", "OPERATOR")
    return jsonify(pcore.load_profile(handle) if pcore else ledger.sync(handle))

@app.route('/api/submit_flag', methods=['POST'])
def submit_flag():
    data = request.json
    handle = data.get("handle", "OPERATOR")
    flag = data.get("flag", "")
    rewards = {
        "FLAG{NAV_USER_99}": {"xp": 500, "hxt": 100},
        "FLAG{RCE_TASK_01}": {"xp": 800, "hxt": 200}
    }
    if flag in rewards:
        r = rewards[flag]
        if pcore:
            pcore.add_progress(handle=handle, xp_gain=r['xp'], hxt_gain=r['hxt'])
        return jsonify({"status": "SUCCESS", "msg": f"Flag Accepted! +{r['xp']} XP"})
    return jsonify({"status": "ERROR", "msg": "Invalid Flag"}), 400

# --- LORE & MAP EXPANSIONS ---
@app.route('/api/n/map', methods=['GET'])
def ncore_map():
    nodes = [
        {"id": "OC-0042", "type": "node-npc", "x": 75, "y": 30, "name": "Director Thorne"},
        {"id": "OREK-NEXUS", "type": "node-backbone", "x": 50, "y": 50, "name": "The Nexus"},
        {"id": "SARAH-CHEN", "type": "node-npc", "x": 80, "y": 40, "name": "Sarah Chen (Defense)"},
        {"id": "ELENA-VANCE", "type": "node-npc", "x": 70, "y": 20, "name": "Elena Vance (Intel)"}
    ]
    
    offset = 10
    for handle in list(active_operators.keys()):
        nodes.append({
            "id": handle, 
            "type": "node-player", 
            "x": offset, "y": 80, 
            "name": f"Operator @{handle}"
        })
        offset = (offset + 15) % 90
        
    return jsonify({"status": "SUCCESS", "nodes": nodes})

