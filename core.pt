# --- ADMIN UTILITIES ---
@app.route('/api/admin/wipe_ghost', methods=['POST'])
def admin_wipe():
    data = request.json
    handle = data.get('handle')
    if not handle: 
        return jsonify({"status": "ERROR", "msg": "Handle required."}), 400
    
    path = f"profiles/{handle}.json"
    if os.path.exists(path):
        os.remove(path)
        return jsonify({"status": "SUCCESS", "msg": f"Profile {handle} purged."})
    return jsonify({"status": "ERROR", "msg": "Profile not found."}), 404

@app.route('/api/admin/install_cartridge', methods=['POST'])
def admin_install():
    file = request.files.get('file')
    if not file: 
        return jsonify({"status": "ERROR", "msg": "No file uploaded"}), 400
    try:
        target_dir = os.path.join(os.path.dirname(os.path.abspath(__file__)), "cartridges")
        os.makedirs(target_dir, exist_ok=True)
        zip_path = os.path.join(target_dir, file.filename)
        file.save(zip_path)
        
        with zipfile.ZipFile(zip_path, 'r') as zip_ref:
            zip_ref.extractall(target_dir)
            
        os.remove(zip_path)
        return jsonify({"status": "SUCCESS", "msg": "Cartridge installed and extracted."})
    except Exception as e:
        return jsonify({"status": "ERROR", "msg": str(e)}), 500

# --- SOCKET EVENTS ---
@socketio.on('buy_item')
def buy_item(data):
    handle = data.get('handle', 'OPERATOR')
    cost = float(data.get('cost', 0))
    profile = pcore.load_profile(handle) if pcore else ledger.sync(handle)
    if profile.get('ledger', 0) >= cost:
        if pcore:
            pcore.add_progress(handle=handle, hxt_cost=cost)
        else:
            profile['ledger'] -= cost
            with open(f"profiles/{handle}.json", 'w') as f: json.dump(profile, f)
        emit('npc_message', {"sender": "KAGE", "text": f"{data['item']} acquired.", "color": "gold"})

@socketio.on('infect_node')
def infect_node(data):
    handle = data.get('handle', 'OPERATOR')
    profile = pcore.load_profile(handle) if pcore else ledger.sync(handle)
    if profile.get('ledger', 0) >= 100:
        if pcore: pcore.add_progress(handle=handle, hxt_cost=100)
        profile['nodes'] = profile.get('nodes', 0) + 1
        if not pcore:
            with open(f"profiles/{handle}.json", 'w') as f: json.dump(profile, f)
        emit('npc_message', {"sender": "KAGE", "text": "Node compromised.", "color": "var(--vanguard)"})

@socketio.on('npc_chat')
def npc_chat(data):
    try:
        msg = data.get('text', '').upper()
        handle = data.get('handle', 'OPERATOR')
        profile = pcore.load_profile(handle) if pcore else ledger.sync(handle)
        
        if "STATUS" in msg:
            resp = f"Operator @{handle}. Level {profile.get('level', 1)}. Nodes: {profile.get('nodes', 0)}."
            emit('npc_message', {"sender": "NYX", "text": resp, "color": "var(--nyx)"})
        elif "HELP" in msg:
            emit('npc_message', {"sender": "P0LYGL07", "text": "Open the World Map to infect nodes for passive HXT.", "color": "var(--vanguard)"})
            
        if s_core: s_core.process_chat(data, socketio, ledger) 
    except Exception as e: 
        print(f"[SOCKET ERR] {e}")

# --- PTY & BACKGROUND ENGINES ---
def read_pty():
    global fd
    while True:
        socketio.sleep(0.01)
        if fd:
            try:
                out = os.read(fd, 1024)
                if out: socketio.emit("terminal_output", {"output": out.decode(errors='ignore')})
            except: break

@socketio.on("terminal_input")
def handle_input(data):
    if fd: os.write(fd, data["input"].encode())

def sniffer_loop():
    while True:
        socketio.sleep(1.2)
        socketio.emit("sniffer_packet", {"raw": f"[TCP] 192.168.1.{random.randint(2, 254)} -> 10.0.0.5"})

def coast_engine():
    while True:
        socketio.sleep(60)
        for handle in list(active_operators.keys()):
            profile = pcore.load_profile(handle) if pcore else ledger.sync(handle)
            if profile.get('nodes', 0) > 0:
                income = profile['nodes'] * 1.5
                if pcore: pcore.add_progress(handle=handle, hxt_gain=income)
                socketio.emit('npc_message', {"sender": "SYSTEM", "text": f"COAST: +{income} HXT", "color": "gold"})

# --- EXPANSION MOUNTING (NO DUPLICATES) ---
if s_core: s_core.init_expansion(app, socketio, ledger)
if ecore: ecore.init_expansion(app, socketio, ledger)
if tcore: tcore.t_logic_init(app, bind_route)
if pcore: pcore.p_logic_init(app, bind_route)

if __name__ == "__main__":
    m, s = pty.openpty()
    if os.fork() == 0:
        os.setsid(); os.dup2(s, 0); os.dup2(s, 1); os.dup2(s, 2); os.execlp("bash", "bash")
    else:
        fd = m
        threading.Thread(target=read_pty, daemon=True).start()
        threading.Thread(target=sniffer_loop, daemon=True).start()
        threading.Thread(target=coast_engine, daemon=True).start()
        socketio.run(app, port=6060, host='0.0.0.0', debug=True, use_reloader=False)
